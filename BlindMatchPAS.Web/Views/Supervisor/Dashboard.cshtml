@model SupervisorDashboardViewModel
@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="stats-grid">
    <div class="metric-card"><span>@Model.AvailableProposals</span><small>Available anonymous proposals</small></div>
    <div class="metric-card"><span>@Model.ExpressedInterestCount</span><small>Interested proposals</small></div>
    <div class="metric-card"><span>@Model.ConfirmedMatchCount</span><small>Confirmed matches</small></div>
    <div class="metric-card"><span>@Model.ExpertiseAreaCount</span><small>Expertise areas</small></div>
</div>

<div class="surface-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <span class="eyebrow">Blind Review Spotlight</span>
            <h2 class="mb-0">High-fit proposals to review</h2>
        </div>
        <a asp-action="Browse" class="btn btn-primary">Browse All</a>
    </div>

    <div class="row g-3">
        @foreach (var proposal in Model.SpotlightProposals)
        {
            <div class="col-lg-4">
                <div class="surface-card h-100 bg-transparent border border-white border-opacity-10">
                    <partial name="_StatusBadge" model="proposal.Status" />
                    <h4 class="mt-3">@proposal.Title</h4>
                    <p class="text-secondary">@proposal.Abstract</p>
                    <div class="tag-row">
                        @foreach (var keyword in proposal.Keywords)
                        {
                            <span class="tag-pill">@keyword</span>
                        }
                    </div>
                    <a asp-action="Details" asp-route-id="@proposal.Id" class="btn btn-soft mt-3">View Anonymous Details</a>
                </div>
            </div>
        }
    </div>
</div>
