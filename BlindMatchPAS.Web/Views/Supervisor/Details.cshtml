@model SupervisorProposalDetailsViewModel
@{
    ViewData["Title"] = "Anonymous Proposal Details";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="surface-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <span class="eyebrow">@Model.ResearchArea</span>
                    <h2>@Model.Title</h2>
                </div>
                <partial name="_StatusBadge" model="Model.Status" />
            </div>

            <div class="content-pairs">
                <div><h4>Abstract</h4><p>@Model.Abstract</p></div>
                <div><h4>Technical Stack</h4><p>@Model.TechnicalStack</p></div>
                <div><h4>Methodology</h4><p>@Model.Methodology</p></div>
                <div>
                    <h4>Keywords</h4>
                    <div class="tag-row">
                        @foreach (var keyword in Model.Keywords)
                        {
                            <span class="tag-pill">@keyword</span>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                @if (!Model.HasExpressedInterest && !Model.CanRevealIdentity)
                {
                    <form asp-action="ExpressInterest" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">Express Interest</button>
                    </form>
                }
                @if (Model.CanConfirmMatch)
                {
                    <form asp-action="ConfirmMatch" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light" data-confirm="Confirm match and reveal identities?">Confirm Match</button>
                    </form>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="surface-card mb-4">
            <span class="eyebrow">Identity Panel</span>
            <h3>Reveal State</h3>
            @if (Model.CanRevealIdentity)
            {
                <p><strong>@Model.StudentName</strong></p>
                <p class="mb-1">@Model.StudentEmail</p>
                <p class="mb-1">@Model.GroupName</p>
                <p class="text-secondary mb-0">@Model.TeamMembers</p>
            }
            else
            {
                <div class="empty-state compact">
                    <i class="bi bi-incognito"></i>
                    <p>Identity is intentionally hidden until a confirmed match exists.</p>
                </div>
            }
        </div>
        <div class="surface-card">
            <span class="eyebrow">Timeline</span>
            <h3>Review lifecycle</h3>
            <div class="timeline">
                @foreach (var item in Model.Timeline)
                {
                    <div class="timeline-item">
                        <strong>@item.Status</strong>
                        <p>@item.Note</p>
                        <small>@item.ChangedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
