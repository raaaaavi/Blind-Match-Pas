@model List<SupervisorProposalCardViewModel>
@{
    ViewData["Title"] = "Interested Proposals";
}

<div class="surface-card">
    <span class="eyebrow">Shortlist</span>
    <h2>Proposals you expressed interest in</h2>

    <div class="row g-3 mt-1">
        @if (Model.Any())
        {
            @foreach (var proposal in Model)
            {
                <div class="col-lg-6">
                    <div class="surface-card h-100 bg-transparent border border-white border-opacity-10">
                        <partial name="_StatusBadge" model="proposal.Status" />
                        <h4 class="mt-3">@proposal.Title</h4>
                        <p class="text-secondary">@proposal.Abstract</p>
                        <a asp-action="Details" asp-route-id="@proposal.Id" class="btn btn-soft">Open Details</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-stars"></i>
                <h3>No interest recorded yet</h3>
                <p>Browse anonymous proposals and shortlist those aligned with your expertise.</p>
            </div>
        }
    </div>
</div>
