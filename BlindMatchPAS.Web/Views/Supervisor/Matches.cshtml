@model List<SupervisorProposalCardViewModel>
@{
    ViewData["Title"] = "Confirmed Matches";
}

<div class="surface-card">
    <span class="eyebrow">Revealed Matches</span>
    <h2>Confirmed supervision allocations</h2>

    <div class="row g-3 mt-1">
        @if (Model.Any())
        {
            @foreach (var proposal in Model)
            {
                <div class="col-lg-6">
                    <div class="surface-card h-100 bg-transparent border border-white border-opacity-10">
                        <partial name="_StatusBadge" model="proposal.Status" />
                        <h4 class="mt-3">@proposal.Title</h4>
                        <p class="mb-1"><strong>Student / Group:</strong> @proposal.RevealedStudentName</p>
                        <p class="mb-1"><strong>Email:</strong> @proposal.RevealedStudentEmail</p>
                        <p class="text-secondary"><strong>Group:</strong> @proposal.RevealedGroupInfo</p>
                        <a asp-action="Details" asp-route-id="@proposal.Id" class="btn btn-primary">Open Match</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-link-45deg"></i>
                <h3>No confirmed matches yet</h3>
                <p>Confirmed matches will appear here with identity details revealed.</p>
            </div>
        }
    </div>
</div>
